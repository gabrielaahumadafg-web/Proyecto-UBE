# Configuración del backend (FastAPI + Supabase).
# El archivo se copia a ".env" y se completa con las credenciales reales del proyecto.
# El ".env" real nunca se versiona; queda excluido mediante .gitignore.

# URL base del proyecto Supabase (Project Settings > API > Project URL).
SUPABASE_URL="https://TU_PROYECTO.supabase.co"

# Clave pública anónima (Project Settings > API > anon public).
SUPABASE_KEY="TU_ANON_KEY"

# Clave de servicio con privilegios elevados (Project Settings > API > service_role).
# Otorga acceso administrativo total: se mantiene exclusivamente en el servidor.
SUPABASE_SERVICE_KEY="TU_SERVICE_ROLE_KEY"

# Orígenes permitidos para CORS, separados por comas (opcional).
# Sin definir, se permite cualquier origen (la auth usa Bearer tokens, no cookies).
ALLOWED_ORIGINS="https://TU_FRONTEND.vercel.app,http://localhost:5173"
