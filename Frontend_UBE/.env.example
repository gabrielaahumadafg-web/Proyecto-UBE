# Configuración del frontend (Vite + React).
# El archivo se copia a ".env.local" y se completa con las credenciales reales.
# El prefijo VITE_ expone las variables al cliente: solo se usan claves públicas.

# URL base del proyecto Supabase.
VITE_SUPABASE_URL="https://TU_PROYECTO.supabase.co"

# Clave pública anónima (anon public). Apta para exponerse en el navegador.
VITE_SUPABASE_ANON_KEY="TU_ANON_KEY"

# URL pública del backend (FastAPI) desplegado.
# En local se omite y se usa http://localhost:8000 por defecto.
# En producción se define con la URL del servicio en Render, p. ej. https://proyecto-ube.onrender.com
VITE_API_URL="https://TU-BACKEND.onrender.com"
